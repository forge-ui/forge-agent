# GitHub Personal Access Token with read:packages scope.
# Get one at: https://github.com/settings/tokens
# Paste here, then `source .env` (or use direnv) before `pnpm install`.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx

# Optional but required for production document artifacts.
# Serve the Umo editor from a dedicated origin, e.g. https://umo.agent.example.com.
NEXT_PUBLIC_UMO_ORIGIN=
